// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  BUY
  SELL
  DIVIDEND
  BONUS
}

enum PortfolioStrategy {
  DividendGrowth
  Retirement
  Speculative
  Education
  Other
}

enum DividendQuarter {
  Q1
  Q2
  Q3
  Q4
  SPECIAL
}

enum DividendStatus {
  ANNOUNCED
  CANCELLED
  PAID
}

enum DividendPaymentStatus {
  UPCOMING
  PAID
  MISSED
}

enum FundingSource {
  CASH
  DIVIDEND
}

model Profile {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  phone       String
  email       String   @unique

  transactions  Transaction[]
  portfolios    Portfolio[]
  holdings      Holding[]
  dividendPayments  DividendPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Stock {
  id        Int      @id @default(autoincrement())
  fullName  String
  symbol    String   @unique
  icon      String

  currentPrice    Decimal   @db.Decimal(18,4)
  dividendYield   Decimal   @db.Decimal(18,4)
  annualDividend  Decimal   @db.Decimal(18,4)

  transactions Transaction[]    // 1 stock may have many transactions
  holdings    Holding[]
  dividendDeclaration  DividendDeclaration[]

  sectorId   Int
  sector   Sector         @relation(fields: [sectorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Sector {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  icon      String

  stocks     Stock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Transaction {
  id String @id @default(cuid())
  
  quantity            Decimal       @db.Decimal(18,4)
  buyingPrice         Decimal       @db.Decimal(18,4)
  totalBuyingPrice    Decimal       @db.Decimal(18,4)
  broker              String
  fundingSource       FundingSource @default(CASH)


  stockId   Int
  stock     Stock         @relation(fields: [stockId], references: [id])

  portfolioId   Int
  portfolio     Portfolio         @relation(fields: [portfolioId], references: [id])

  profileId   Int
  profile     Profile         @relation(fields: [profileId], references: [id])

  purchaseDate     DateTime     @db.Date 
  transactionType  TransactionType
  
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}


model Portfolio {
  id            Int          @id @default(autoincrement())
  name         String
  strategy      String
  description   String

  transactions  Transaction[]
  holdings      Holding[]
  dividendPayments  DividendPayment[]

  profileId     Int
  profile       Profile      @relation(fields: [profileId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}


model Holding {
  id        Int       @id @default(autoincrement())
  quantity  Decimal   @db.Decimal(18,4)
  avgPrice  Decimal   @db.Decimal(18,4)
  totalCost Decimal   @db.Decimal(18,4)
  
  stockId   Int
  stocks    Stock         @relation(fields: [stockId], references: [id])

  profileId     Int
  profile       Profile      @relation(fields: [profileId], references: [id])

  portfolioId   Int
  portfolio     Portfolio         @relation(fields: [portfolioId], references: [id])

  dividendPayments  DividendPayment[]

  @@unique([portfolioId, stockId])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}


model DividendDeclaration {
  id String @id @default(cuid())

  stockId     Int
  stock       Stock @relation(fields: [stockId], references: [id])

  dividendPerShare    Decimal     @db.Decimal(18,4)

  announcementDate    DateTime?
  exDividendDate      DateTime

  bookClosureDate     DateTime

  paymentDate       DateTime
  financialYear     Int?

  quarter       DividendQuarter?
  status        DividendStatus      @default(ANNOUNCED)

  payments DividendPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

}


model DividendPayment {
  id      String      @id     @default(cuid())

  eligibleShares    Decimal     @db.Decimal(18,4)
  grossDividend     Decimal     @db.Decimal(18,4)

  taxRate       Decimal?    @db.Decimal(5,2)
  taxAmount     Decimal?    @db.Decimal(18,4)
  netDividend   Decimal     @db.Decimal(18,4)

  status    DividendPaymentStatus   @default(UPCOMING)
  paidAt    DateTime?

  profileId     Int
  profile       Profile      @relation(fields: [profileId], references: [id])

  declarationId     String
  declaration       DividendDeclaration   @relation(fields: [declarationId], references: [id])

  portfolioId     Int
  portfolio       Portfolio     @relation(fields: [portfolioId], references: [id])

  holdingId       Int
  holding         Holding       @relation(fields: [holdingId], references: [id])


  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}


model Goal {
  id            Int      @id @default(autoincrement())
  title         String
  forcastYear   Int
  
  currentCorpus   Int
  targetCorpus    Int

  expectedHoldingPeriod    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

