// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  BUY
  SELL
  DIVIDEND
  BONUS
}

enum PortfolioStrategy {
  DividendGrowth
  Retirement
  Speculative
  Education
  Other
}

model Profile {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  phone       String
  email       String   @unique

  transactions  Transaction[]
  portfolios    Portfolio[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Sector {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  icon      String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Stock {
  id        Int      @id @default(autoincrement())
  fullName  String
  symbol    String   @unique
  icon      String

  transactions Transaction[]    // 1 stock may have many transactions
  holdings    Holding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Transaction {
  id String @id @default(cuid())
  
  quantity            Decimal @db.Decimal(18,4)
  buyingPrice         Decimal @db.Decimal(18,4)
  totalBuyingPrice    Decimal @db.Decimal(18,4)
  broker              String

  stockId   Int
  stock     Stock         @relation(fields: [stockId], references: [id])

  portfolioId   Int
  portfolio     Portfolio         @relation(fields: [portfolioId], references: [id])

  profileId   Int
  profile     Profile         @relation(fields: [profileId], references: [id])

  purchaseDate     DateTime     @db.Date 
  transactionType  TransactionType
  
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}


model Portfolio {
  id            Int          @id @default(autoincrement())
  name         String
  strategy      String
  description   String

  transactions  Transaction[]
  holdings      Holding[]

  profileId     Int
  profile       Profile      @relation(fields: [profileId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Holding {
  id        Int      @id @default(autoincrement())
  quantity  Decimal   @db.Decimal(18,4)
  avgPrice  Decimal   @db.Decimal(18,4)
  totalCost Decimal   @db.Decimal(18,4)
  
  stockId   Int
  stocks     Stock         @relation(fields: [stockId], references: [id])

  portfolioId   Int
  portfolio     Portfolio         @relation(fields: [portfolioId], references: [id])

  @@unique([portfolioId, stockId])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

model Goal {
  id            Int      @id @default(autoincrement())
  title         String
  forcastYear   Int
  
  currentCorpus   Int
  targetCorpus    Int
  
  expectedHoldingPeriod    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}

